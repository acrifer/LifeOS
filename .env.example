MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=lifeos
MYSQL_USERNAME=replace-with-db-username
MYSQL_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-db-root-password
MYSQL_JDBC_PARAMS=useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MYSQL_JDBC_URL=jdbc:mysql://127.0.0.1:3306/lifeos?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0

NACOS_HOST=127.0.0.1
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_HOME=C:\environment\nacos

ROCKETMQ_HOME=C:\environment\rocketmq-all-5.4.0-bin-release
ROCKETMQ_NAMESRV_HOST=127.0.0.1
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_NAMESRV_ADDR=127.0.0.1:9876
ROCKETMQ_BROKER_PORT=10911

LIFEOS_GATEWAY_PORT=8080
LIFEOS_USER_SERVICE_PORT=8081
LIFEOS_TASK_SERVICE_PORT=8082
LIFEOS_NOTE_SERVICE_PORT=8083
LIFEOS_AI_SERVICE_PORT=8084
LIFEOS_BEHAVIOR_SERVICE_PORT=8085

LIFEOS_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LIFEOS_AI_API_KEY=
LIFEOS_AI_MODEL=glm-4.5-air
LIFEOS_JWT_SECRET=replace-with-a-32-plus-char-secret
LIFEOS_JWT_EXPIRATION_MS=86400000
